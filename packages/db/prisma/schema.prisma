generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String            @unique
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  accounts        Account[]
  sessions        Session[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  memberships     WorkspaceMember[]
  assessments     Assessment[]      @relation("AssessmentCreator")
}

model Account {
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Workspace {
  id           String            @id @default(cuid())
  name         String
  slug         String            @unique
  ownerId      String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  owner        User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members      WorkspaceMember[]
  applications Application[]
  assessments  Assessment[]

  @@index([ownerId])
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  createdAt   DateTime      @default(now())

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Application {
  id            String       @id @default(cuid())
  workspaceId   String
  name          String
  slug          String
  description   String?
  industry      String?
  businessModel String?
  systemType    SystemType   @default(OTHER)
  teamSize      TeamSize?
  trafficLevel  TrafficLevel?
  stackSummary  String?
  primaryGoal   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assessments   Assessment[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
}

model Assessment {
  id                   String            @id @default(cuid())
  workspaceId          String
  applicationId        String
  createdById          String
  status               AssessmentStatus  @default(DRAFT)
  questionnaireVersion String
  submittedAt          DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  workspace            Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  application          Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdBy            User              @relation("AssessmentCreator", fields: [createdById], references: [id], onDelete: Cascade)
  answers              AssessmentAnswer[]
  analysisRuns         AnalysisRun[]

  @@index([workspaceId])
  @@index([applicationId])
  @@index([createdById])
}

model AssessmentAnswer {
  id              String      @id @default(cuid())
  assessmentId    String
  sectionKey      String
  questionKey     String
  valueJson       Json
  normalizedValue Float?
  weightSnapshot  Float?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  assessment      Assessment  @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, questionKey])
  @@index([assessmentId, sectionKey])
}

model AnalysisRun {
  id                  String             @id @default(cuid())
  assessmentId        String
  status              AnalysisRunStatus  @default(PENDING)
  scoringModelVersion String
  aiModel             String?
  startedAt           DateTime?
  completedAt         DateTime?
  errorMessage        String?
  createdAt           DateTime           @default(now())

  assessment          Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  scorecard           Scorecard?
  risks               RiskItem[]
  recommendations     Recommendation[]
  executiveReport     ExecutiveReport?

  @@index([assessmentId])
  @@index([status])
}

model Scorecard {
  id                   String       @id @default(cuid())
  analysisRunId        String       @unique
  overallScore         Float
  architectureScore    Float
  performanceScore     Float
  scalabilityScore     Float
  maintainabilityScore Float
  operabilityScore     Float
  breakdownJson        Json
  createdAt            DateTime     @default(now())

  analysisRun          AnalysisRun  @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model RiskItem {
  id            String         @id @default(cuid())
  analysisRunId String
  title         String
  category      String
  severity      RiskSeverity
  likelihood    RiskLikelihood
  impact        RiskImpact
  priority      RiskPriority
  description   String
  evidenceJson  Json?
  createdAt     DateTime       @default(now())

  analysisRun   AnalysisRun    @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId])
  @@index([priority])
}

model Recommendation {
  id             String                @id @default(cuid())
  analysisRunId  String
  title          String
  category       String
  priority       RiskPriority
  effort         RecommendationEffort
  expectedImpact RecommendationImpact
  description    String
  createdAt      DateTime              @default(now())

  analysisRun    AnalysisRun           @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@index([analysisRunId])
  @@index([priority])
}

model ExecutiveReport {
  id               String       @id @default(cuid())
  analysisRunId    String       @unique
  executiveSummary String
  technicalSummary String
  roadmapJson      Json
  artifactsJson    Json?
  generatedAt      DateTime     @default(now())

  analysisRun      AnalysisRun  @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum AssessmentStatus {
  DRAFT
  SUBMITTED
  ANALYZED
}

enum AnalysisRunStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SystemType {
  SAAS
  ECOMMERCE
  INTERNAL_TOOL
  CONTENT_PLATFORM
  MARKETPLACE
  OTHER
}

enum TeamSize {
  SOLO
  SMALL
  MEDIUM
  LARGE
}

enum TrafficLevel {
  LOW
  MODERATE
  HIGH
  VERY_HIGH
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskLikelihood {
  LOW
  MEDIUM
  HIGH
}

enum RiskImpact {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RecommendationEffort {
  LOW
  MEDIUM
  HIGH
}

enum RecommendationImpact {
  LOW
  MEDIUM
  HIGH
  TRANSFORMATIVE
}
