{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@seventec-atlas/db": ["packages/db/src/index.ts"],
      "@seventec-atlas/domain": ["packages/domain/src/index.ts"],
      "@seventec-atlas/scoring-core": ["packages/scoring-core/src/index.ts"],
      "@seventec-atlas/ai-contracts": ["packages/ai-contracts/src/index.ts"],
      "@seventec-atlas/ui": ["packages/ui/src/index.ts"]
    }
  }
}

