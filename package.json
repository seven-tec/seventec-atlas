{
  "name": "seventec-atlas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "turbo dev",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-local.ps1",
    "local:prepare": "powershell -ExecutionPolicy Bypass -File ./scripts/local-prepare.ps1",
    "local:demo": "powershell -ExecutionPolicy Bypass -File ./scripts/local-demo.ps1",
    "start:local:prod": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local-prod.ps1",
    "local:verify": "powershell -ExecutionPolicy Bypass -File ./scripts/verify-local-release.ps1",
    "db:local:up": "powershell -ExecutionPolicy Bypass -File ./scripts/db-local.ps1 up",
    "db:local:down": "powershell -ExecutionPolicy Bypass -File ./scripts/db-local.ps1 down",
    "db:local:status": "powershell -ExecutionPolicy Bypass -File ./scripts/db-local.ps1 status",
    "db:local:logs": "powershell -ExecutionPolicy Bypass -File ./scripts/db-local.ps1 logs",
    "build": "npm --prefix apps/web run build",
    "lint": "npm --prefix apps/web run lint",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "test:scoring-core": "node --experimental-strip-types --test tests/scoring-core.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:local": "powershell -ExecutionPolicy Bypass -File ./scripts/run-e2e-local.ps1",
    "typecheck": "tsc --noEmit -p apps/web/tsconfig.json",
    "demo:seed": "node --experimental-strip-types ./scripts/seed-demo.ts",
    "screenshots:i18n": "node ./scripts/capture-final-i18n.mjs",
    "db:generate": "npm --prefix packages/db run db:generate",
    "db:migrate": "npm --prefix packages/db run db:migrate",
    "db:migrate:deploy": "npm --prefix packages/db run db:migrate:deploy"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.51.1",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.5.19",
    "globals": "^16.3.0",
    "next": "^15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "turbo": "^2.0.12",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
